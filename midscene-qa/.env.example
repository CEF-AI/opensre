# ─────────────────────────────────────────────────────────────────────────────
# Midscene model configuration. Copy this file to `.env` and fill in a key.
# Midscene reads all model config from env vars and talks to any OpenAI-compatible
# /v1 endpoint. The KEY DETAIL for accuracy: MIDSCENE_MODEL_FAMILY tells Midscene
# how to do visual grounding for your model. Get it wrong and element location
# will be inaccurate. Valid values:
#
#   Model            MIDSCENE_MODEL_FAMILY
#   ----------------------------------------
#   Qwen2.5-VL       qwen2.5-vl
#   Qwen3-VL         qwen3-vl
#   Qwen3.x          qwen3
#   UI-TARS 1.0      vlm-ui-tars
#   UI-TARS 1.5      vlm-ui-tars-doubao-1.5
#   GLM-4.6V / 5V    glm-v
#   Gemini 3.x       gemini
#   Doubao Seed      doubao-seed
#   GPT-5            gpt-5
# ─────────────────────────────────────────────────────────────────────────────

# ── Default for this POC: Qwen3-VL via OpenRouter (cheap + strong UI grounding) ──
MIDSCENE_MODEL_BASE_URL="https://openrouter.ai/api/v1"
MIDSCENE_MODEL_API_KEY="sk-or-v1-REPLACE_ME"
MIDSCENE_MODEL_NAME="qwen/qwen3-vl-235b-a22b-instruct"
MIDSCENE_MODEL_FAMILY="qwen3-vl"

# ── Cheapest grounding option: UI-TARS 1.5 7B via OpenRouter ($0.10/Mtok) ──
# MIDSCENE_MODEL_NAME="bytedance/ui-tars-1.5-7b"
# MIDSCENE_MODEL_FAMILY="vlm-ui-tars-doubao-1.5"

# ── Officially-recommended option: Qwen2.5-VL 72B via OpenRouter ($0.80/Mtok) ──
# MIDSCENE_MODEL_NAME="qwen/qwen2.5-vl-72b-instruct"
# MIDSCENE_MODEL_FAMILY="qwen2.5-vl"

# ── GLM-4.6V via OpenRouter ($0.30/Mtok) ──
# MIDSCENE_MODEL_NAME="z-ai/glm-4.6v"
# MIDSCENE_MODEL_FAMILY="glm-v"

# ── Debugging ──
# Save every step's screenshot + LLM prompt/response for inspection.
# MIDSCENE_RUN_DIR="./midscene_run"
